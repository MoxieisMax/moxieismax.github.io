---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  
  {% for page in site.pages %}
    {% unless page.url contains '/files/' or page.url contains '/session-state/' %}
    {% if page.title %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    {% if page.last_updated %}
    <lastmod>{{ page.last_updated | date_to_xmlschema }}</lastmod>
    {% else %}
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    {% endif %}
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
    {% endif %}
    {% endunless %}
  {% endfor %}
  
  {% for guide in site.guides %}
  <url>
    <loc>{{ site.url }}{{ guide.url }}</loc>
    {% if guide.last_updated %}
    <lastmod>{{ guide.last_updated | date_to_xmlschema }}</lastmod>
    {% else %}
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    {% endif %}
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endfor %}
  
  {% for money in site.money %}
  <url>
    <loc>{{ site.url }}{{ money.url }}</loc>
    {% if money.last_updated %}
    <lastmod>{{ money.last_updated | date_to_xmlschema }}</lastmod>
    {% else %}
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    {% endif %}
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  {% endfor %}
</urlset>
